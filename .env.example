# Application
APP_VERSION=latest
TZ=Europe/Moscow

# Public domain served by Traefik (без https:// и без www)
APP_DOMAIN=guardgame.vzhyx.io

# Прокси для шага `docker build` — оставь пустыми, если интернет в РФ доступен.
# Если используешь xray/v2ray-клиент с VLESS+Reality на хосте,
# слушающий HTTP-прокси на 127.0.0.1:1081, раскомментируй:
# BUILD_HTTP_PROXY=http://127.0.0.1:1081
# BUILD_HTTPS_PROXY=http://127.0.0.1:1081
# BUILD_NO_PROXY=localhost,127.0.0.1,.local
BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=
BUILD_NO_PROXY=localhost,127.0.0.1
